{
  "name": "media-tools",
  "description": "Cut and export audio offline and privately — nothing is uploaded.",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier -w .",
    "check": "npm run compile && npm run lint && npm run test",
    "postinstall": "wxt prepare",
    "capture": "node tests/e2e/capture.mjs"
  },
  "dependencies": {
    "lamejs": "1.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/selenium-webdriver": "4.35.6",
    "@wxt-dev/module-react": "1.2.2",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "selenium-webdriver": "4.46.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "web-ext": "10.5.0",
    "wxt": "0.20.27"
  }
}
